<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="20dp">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@android:drawable/ic_dialog_info"
        android:contentDescription="Ícone Biometria" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Segurança Reforçada"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Deseja utilizar sua digital para entrar no Trocabook de forma mais rápida e segura?"
        android:textAlignment="center"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnAtivarBiometria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ATIVAR BIOMETRIA"
        android:layout_marginTop="40dp"
        android:backgroundTint="#673AB7"/>

    <Button
        android:id="@+id/btnPularBiometria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AGORA NÃO"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>

</LinearLayout>