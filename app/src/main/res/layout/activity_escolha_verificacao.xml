<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verificação de Segurança"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Como deseja receber seu código?"
        android:textSize="16sp"
        android:layout_marginBottom="32dp"
        android:textAlignment="center"/>

    <Button
        android:id="@+id/btnEscolhaEmail"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Enviar por E-mail"
        android:textAllCaps="false"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#673AB7" />

    <Button
        android:id="@+id/btnEscolhaSMS"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Enviar por SMS"
        android:textAllCaps="false"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#673AB7" />

    <Button
        android:id="@+id/btnVoltarEscolha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VOLTAR"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>

</LinearLayout>